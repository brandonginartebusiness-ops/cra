# Copy to .env for local dev only. Do not commit real values.
# Production: set in Vercel → Settings → Environment Variables

ANTHROPIC_API_KEY=
# Optional — default is claude-haiku-4-5-20251001; e.g. claude-sonnet-4-6 for quality
ANTHROPIC_MODEL=
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Ad-tracking pixels — leave blank to disable each provider
# Meta (Facebook/Instagram) Pixel + Conversions API
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Google Ads conversion tracking via gtag
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=
# TikTok Pixel
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
# Microsoft Clarity
NEXT_PUBLIC_MS_CLARITY_ID=
